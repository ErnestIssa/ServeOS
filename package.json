{
  "name": "serveos",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "services/*",
    "core/*",
    "packages/*"
  ],
  "overrides": {
    "esbuild": "0.27.2",
    "react-native-worklets": "0.5.1"
  },
  "dependencies": {
    "@types/react": "19.1.17",
    "@types/react-dom": "19.1.9",
    "react-native-worklets": "0.5.1"
  },
  "scripts": {
    "build": "npm run build:backend",
    "build:backend": "npm run build -w @serveos/api",
    "start:backend": "npm run start -w @serveos/api",
    "dev": "turbo run dev --parallel",
    "dev:web-admin": "npm run dev -w @serveos/web-admin",
    "dev:customer-web": "npm run dev -w @serveos/customer-web",
    "dev:api-gateway": "npm run dev -w @serveos/api-gateway",
    "dev:auth-service": "npm run dev -w @serveos/auth-service",
    "dev:restaurant-service": "npm run dev -w @serveos/restaurant-service",
    "dev:order-service": "npm run dev -w @serveos/order-service",
    "dev:api": "npm run dev -w @serveos/api",
    "dev:backend": "turbo run dev --parallel --filter=@serveos/api",
    "dev:backend:legacy": "turbo run dev --parallel --filter=@serveos/api-gateway --filter=@serveos/auth-service --filter=@serveos/restaurant-service --filter=@serveos/order-service",
    "dev:payment-service": "npm run dev -w @serveos/payment-service",
    "dev:notification-service": "npm run dev -w @serveos/notification-service",
    "format": "prettier . --write",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate:deploy": "prisma migrate deploy --schema core/database/prisma/schema.prisma",
    "db:migrate:status": "prisma migrate status --schema core/database/prisma/schema.prisma",
    "db:generate": "prisma generate --schema core/database/prisma/schema.prisma",
    "db:studio": "prisma studio --schema core/database/prisma/schema.prisma",
    "db:seed": "npm run db:seed -w @serveos/core-database"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "prisma": "^6.16.1",
    "turbo": "^2.5.6",
    "typescript": "^5.7.3"
  }
}

