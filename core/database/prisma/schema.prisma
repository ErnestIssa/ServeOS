generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  MANAGER
  STAFF
  KITCHEN
  CASHIER
  CUSTOMER
}

/// Venue membership lifecycle — restaurant access requires ACTIVE.
enum MembershipStatus {
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
  REMOVED
  REJECTED
}

/// Staff invitation delivery / acceptance state (notifications sent separately).
enum StaffInvitationStatus {
  PENDING
  ACCEPTED
  CANCELLED
  EXPIRED
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  phone     String?  @unique
  password  String
  role      Role
  /// Wizard / registration snapshot (JSON). Used to restore context on next login; not a substitute for typed domain models.
  /// Customer preferred venue id is also stored here under `preferredRestaurantId` (see customer routes + /auth/me).
  signupProfile Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships   Membership[]
  notifications Notification[]
  notificationPreference UserNotificationPreference?
  accountProfile UserAccountProfile?
  appPreferences UserAppPreferences?
  sessions      UserSession[]
  securityActivity SecurityActivity[]
  emailChangeRequests EmailChangeRequest[]
  twoFactorAuth UserTwoFactorAuth?
  accountClosureRequests AccountClosureRequest[]
  ownershipTransferRequests OwnershipTransferRequest[] @relation("OwnershipTransferFrom")
  passwordResetRequests PasswordResetRequest[]
  customerOrders Order[] @relation("CustomerOrders")
  shoppingCarts ShoppingCart[]
  customerChatRooms ChatRoom[] @relation("CustomerChatRooms")
  reservationDrafts CustomerReservationDraft[]
  customerReservations CustomerReservation[]
  deviceTokens         UserDeviceToken[]
  staffAuditsAsActor   StaffAuditLog[] @relation("StaffAuditActor")
  staffAuditsAsTarget  StaffAuditLog[] @relation("StaffAuditTarget")
  communicationSubscriber CommunicationSubscriber?
}

/// Owner/staff personal profile — SSOT for admin profile page (distinct from signupProfile snapshot).
model UserAccountProfile {
  userId          String   @id
  fullName        String?
  phone           String?
  jobTitle        String?
  profileImageUrl String?
  profileImageKey String?
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Per-user locale / display preferences.
model UserAppPreferences {
  userId     String   @id
  language   String   @default("en")
  timezone   String   @default("Europe/Stockholm")
  dateFormat String   @default("YYYY-MM-DD")
  timeFormat String   @default("24h")
  theme      String   @default("system")
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Active auth sessions per device/browser — keyed by JWT fingerprint.
model UserSession {
  id               String    @id @default(cuid())
  userId           String
  tokenFingerprint String    @unique
  deviceName       String?
  browser          String?
  ipMasked         String?
  location         String?
  userAgent        String?
  lastActiveAt     DateTime  @default(now())
  createdAt        DateTime  @default(now())
  revokedAt        DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, lastActiveAt])
}

enum SecurityActivityType {
  LOGIN_SUCCESS
  LOGIN_FAILED
  PASSWORD_CHANGED
  PASSWORD_RESET_REQUESTED
  EMAIL_CHANGE_REQUESTED
  EMAIL_CHANGED
  TWO_FA_ENABLED
  TWO_FA_DISABLED
  SESSION_REVOKED
  SESSIONS_REVOKED_ALL
  OWNERSHIP_TRANSFER_REQUESTED
  ACCOUNT_CLOSURE_REQUESTED
  PROFILE_UPDATED
}

model SecurityActivity {
  id        String               @id @default(cuid())
  userId    String
  type      SecurityActivityType
  metadata  Json?
  ipMasked  String?
  createdAt DateTime             @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model EmailChangeRequest {
  id                 String    @id @default(cuid())
  userId             String
  newEmail           String
  tokenHash          String    @unique
  passwordVerifiedAt DateTime?
  expiresAt          DateTime
  consumedAt         DateTime?
  createdAt          DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserTwoFactorAuth {
  userId         String    @id
  secretEnc      String
  enabled        Boolean   @default(false)
  backupCodesHash Json?
  lastVerifiedAt DateTime?
  enabledAt      DateTime?
  updatedAt      DateTime  @updatedAt
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AccountClosureRequest {
  id           String   @id @default(cuid())
  userId       String
  reason       String?
  status       String   @default("PENDING")
  coolingUntil DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model PasswordResetRequest {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OwnershipTransferRequest {
  id                 String    @id @default(cuid())
  fromUserId         String
  toEmail            String
  toUserId           String?
  restaurantId       String
  status             String    @default("PENDING")
  passwordVerifiedAt DateTime?
  twoFaVerifiedAt    DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  fromUser User @relation("OwnershipTransferFrom", fields: [fromUserId], references: [id], onDelete: Cascade)

  @@index([fromUserId, status])
}

model Company {
  id                    String       @id @default(cuid())
  ///Digits-only normalization of org/registry number for stable upserts across clients.
  orgNumberNormalized String      @unique
  legalName              String
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  restaurants Restaurant[]
}

enum StoredMediaScope {
  PROFILE_IMAGE
  RESTAURANT_IMAGE
  MENU_IMAGE
  CHAT_IMAGE
  VIDEO
  PDF
  INVOICE
  DOCUMENT
  ATTACHMENT
}

enum StoredMediaVisibility {
  PUBLIC
  PRIVATE
}

model StoredMedia {
  id            String                @id @default(cuid())
  objectKey     String                @unique
  scope         StoredMediaScope
  contentType   String
  byteSize      Int
  sha256Hex     String?
  visibility    StoredMediaVisibility @default(PRIVATE)
  originalName  String?
  uploadedById  String?
  restaurantId  String?
  userId        String?
  menuItemId    String?
  chatRoomId    String?
  chatMessageId String?               @unique
  /// Gallery order within a menu item (images and videos sorted separately).
  sortOrder     Int                   @default(0)
  /// Client-reported duration for short item videos (ms).
  durationMs    Int?
  createdAt     DateTime              @default(now())

  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: SetNull)
  menuItem   MenuItem?   @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  @@index([restaurantId, scope])
  @@index([menuItemId, scope, sortOrder])
  @@index([userId])
  @@index([chatRoomId])
}

model Restaurant {
  id           String   @id @default(cuid())
  name         String
  openingHours String?  // later: structured JSON
  /// Customer-facing call line (primary when customers tap Call in chat).
  customerCallLine String?
  /// Registered venue phone (fallback when customer call line is unset).
  registeredPhone  String?
  logoImageKey  String?
  coverImageKey String?

  companyId               String?
  company                 Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ///UI classification (restaurant/café/bakery/other); persisted under the unified Restaurant aggregate.
  venueSubtype            String?
  venueSubtypeOther       String?
  establishmentLocation    String?
  offeringsDescription    String?
  /// Owner-configured caps: maxManagers, allowManagersToInviteManagers, etc.
  accessPolicy            Json?
  /// Per-venue order engine rules (cancellation, SLA, auto-accept, refunds).
  orderEnginePolicy       Json?
  /// Per-venue order identity rules (display number reset, tracking code format).
  orderIdentityPolicy     Json?
  /// Per-venue order source rule overrides.
  orderSourcePolicy       Json?
  /// Stripe/Swish connect, accepted methods, rules, taxes, refunds.
  paymentSettings         Json?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships       Membership[]
  staffInvitations  StaffInvitation[]
  customerInvitations CustomerInvitation[]
  menuCategories MenuCategory[]
  menus          Menu[]
  orderingSessions OrderingSession[]
  orders         Order[]
  orderCounter   RestaurantOrderCounter?
  shoppingCarts  ShoppingCart[]
  sessionCarts   SessionCart[]
  chatRooms      ChatRoom[]
  reservationDrafts CustomerReservationDraft[]
  customerReservations CustomerReservation[]
  storedMedia        StoredMedia[]
  staffAuditLogs     StaffAuditLog[]

  @@index([companyId])
}

/// Recent staff action velocity window for fraud detection (in-memory substitute persisted per actor).
model TrustActionVelocity {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  actionType  String
  count       Int      @default(1)
  windowStart DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([workspaceId, userId, actionType])
  @@index([workspaceId, userId])
}

/// In-progress customer table booking per venue (mobile Book tab); server source of truth.
model CustomerReservationDraft {
  id                 String   @id @default(cuid())
  userId             String
  restaurantId       String
  screenId           String   @default("landing")
  draft              Json
  confirmationCode   String?
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
  @@index([restaurantId])
}

enum CustomerReservationStatus {
  CONFIRMED
  CANCELLED
  COMPLETED
}

/// Confirmed table booking — server source of truth for upcoming visits.
model CustomerReservation {
  id               String                    @id @default(cuid())
  userId           String
  restaurantId     String
  confirmationCode String                    @unique
  status           CustomerReservationStatus @default(CONFIRMED)
  startsAt         DateTime
  draft            Json
  updatedAt        DateTime                  @updatedAt
  createdAt        DateTime                  @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  chatRoom   ChatRoom?

  @@index([userId, status, startsAt])
  @@index([restaurantId])
}

model Membership {
  id           String           @id @default(cuid())
  userId       String
  restaurantId String
  role         Role
  status       MembershipStatus @default(ACTIVE)
  /// Granular venue permissions (string keys). Backend-enforced source of truth.
  permissions  Json?
  invitedByUserId   String?
  approvedByUserId  String?
  approvedAt        DateTime?
  suspendedAt       DateTime?
  removedAt         DateTime?
  rejectedAt        DateTime?
  staffInvitationId String?          @unique
  customerInvitationId String?       @unique
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant      Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  staffInvitation StaffInvitation? @relation(fields: [staffInvitationId], references: [id], onDelete: SetNull)
  customerInvitation CustomerInvitation? @relation(fields: [customerInvitationId], references: [id], onDelete: SetNull)

  @@unique([userId, restaurantId])
  @@index([restaurantId, status])
}

/// Restaurant-controlled staff invite — must be accepted + approved before venue access.
model StaffInvitation {
  id             String               @id @default(cuid())
  restaurantId   String
  fullName       String
  email          String
  phone          String?
  intendedRole   Role
  permissions    Json
  tokenHash      String               @unique
  status         StaffInvitationStatus @default(PENDING)
  expiresAt      DateTime
  invitedByUserId String
  acceptedByUserId String?
  acceptedAt     DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  restaurant Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  membership Membership?

  @@index([restaurantId, status])
  @@index([email])
}

/// Restaurant → customer enrollment (loyalty, reservations, order tracking).
model CustomerInvitation {
  id               String                @id @default(cuid())
  restaurantId     String
  fullName         String?
  email            String
  phone            String?
  tokenHash        String                @unique
  status           StaffInvitationStatus @default(PENDING)
  expiresAt        DateTime
  invitedByUserId  String?
  acceptedByUserId String?
  acceptedAt       DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  restaurant Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  membership Membership?

  @@index([restaurantId, status])
  @@index([email])
}

model MenuCategory {
  id           String   @id @default(cuid())
  restaurantId String
  menuId       String?
  name         String
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menu       Menu?      @relation(fields: [menuId], references: [id], onDelete: SetNull)
  items      MenuItem[]

  @@index([restaurantId])
  @@index([menuId])
}

enum MenuStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

/// Versioned menu surface — draft → publish creates immutable MenuVersion snapshot.
model Menu {
  id              String     @id @default(cuid())
  restaurantId    String
  name            String
  description     String?
  surfaceKey      String?
  status          MenuStatus @default(DRAFT)
  activeVersionId String?    @unique
  createdByUserId String
  sortOrder            Int        @default(0)
  scheduledPublishAt   DateTime?
  availabilityWindows  Json?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  restaurant    Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categories    MenuCategory[]
  versions      MenuVersion[]
  activeVersion MenuVersion?  @relation("ActiveMenuVersion", fields: [activeVersionId], references: [id], onDelete: SetNull)

  @@index([restaurantId, status])
  @@index([restaurantId, sortOrder])
}

model MenuVersion {
  id              String    @id @default(cuid())
  menuId          String
  versionNumber   Int
  snapshot        Json?
  publishedAt     DateTime?
  createdByUserId String
  createdAt       DateTime  @default(now())

  menu          Menu  @relation(fields: [menuId], references: [id], onDelete: Cascade)
  activeForMenu Menu? @relation("ActiveMenuVersion")

  @@unique([menuId, versionNumber])
  @@index([menuId])
}

enum OrderingSessionType {
  QR_SESSION
  WALK_IN_SESSION
  LINK_SESSION
  STAFF_ASSISTED_SESSION
}

enum OrderingSessionStatus {
  ACTIVE
  EXPIRED
  CLOSED
}

enum OrderingPaymentMode {
  PAY_AT_VENUE
  PREPAY
  HYBRID
}

/// Guest / QR ordering context — ties menu browse, cart, and placement together.
model OrderingSession {
  id           String                @id @default(cuid())
  restaurantId String
  sessionType  OrderingSessionType     @default(QR_SESSION)
  status       OrderingSessionStatus   @default(ACTIVE)
  entryMode    String?
  tableId      String?
  tableLabel   String?
  locationId   String?
  paymentMode  OrderingPaymentMode     @default(PREPAY)
  expiresAt    DateTime
  lastActiveAt DateTime              @default(now())
  createdAt    DateTime              @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  cart       SessionCart?

  @@index([restaurantId, status])
  @@index([expiresAt])
}

/// Guest cart scoped to an ordering session (QR / link flows).
model SessionCart {
  id                String   @id @default(cuid())
  orderingSessionId String   @unique
  restaurantId      String
  orderNote         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  orderingSession OrderingSession @relation(fields: [orderingSessionId], references: [id], onDelete: Cascade)
  restaurant      Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  lines           SessionCartLine[]

  @@index([restaurantId])
}

model SessionCartLine {
  id                String @id @default(cuid())
  sessionCartId     String
  menuItemId        String
  quantity          Int    @default(1)
  modifierOptionIds Json   @default("[]")

  sessionCart SessionCart @relation(fields: [sessionCartId], references: [id], onDelete: Cascade)
  menuItem    MenuItem    @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([sessionCartId])
}

model MenuItem {
  id          String   @id @default(cuid())
  categoryId  String
  name        String
  description String?
  priceCents  Int
  imageKey    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category       MenuCategory    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  modifierGroups ModifierGroup[]
  orderLineItems OrderLineItem[]
  cartLines      CartLine[]
  sessionCartLines SessionCartLine[]
  storedMedia    StoredMedia[]

  @@index([categoryId])
}

model ShoppingCart {
  id             String   @id @default(cuid())
  userId         String
  restaurantId   String
  /// Customer kitchen note — persisted until checkout or cart cleared.
  orderNote      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  lines      CartLine[]

  @@unique([userId, restaurantId])
  @@index([restaurantId])
}

model CartLine {
  id                String @id @default(cuid())
  cartId            String
  menuItemId        String
  quantity          Int    @default(1)
  /// Sorted string[] of ModifierOption ids for this line (JSON array).
  modifierOptionIds Json   @default("[]")

  cart     ShoppingCart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  menuItem MenuItem     @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([cartId])
}

enum OrderStatus {
  /// Legacy — migrated to CREATED; kept for backward-compatible reads.
  PENDING
  /// Legacy — migrated to ACCEPTED; kept for backward-compatible reads.
  CONFIRMED
  CREATED
  PENDING_PAYMENT
  PAID
  ACCEPTED
  REJECTED
  PREPARING
  READY
  COMPLETED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
  ARCHIVED
}

enum OrderSource {
  QR_ORDER
  STAFF_CREATED
  WALK_IN
  PHONE_ORDER
  RESERVATION
  RESERVATION_ORDER
  DELIVERY_PARTNER
}

enum OrderPaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIAL_REFUND
}

enum OrderActorSource {
  CUSTOMER
  STAFF
  SYSTEM
  PAYMENT
  ADMIN
}

/// Immutable context at order creation — customer identity cannot be overridden by role switching.
enum OrderCreatedContext {
  CUSTOMER
  STAFF
}

enum TrustEventType {
  FRAUD_DETECTED
  APPROVAL_REQUESTED
  APPROVED
  REJECTED
  EXECUTED
  BLOCKED
  AUDIT_LOG
}

enum TrustEntityType {
  ORDER
  PAYMENT
  USER
  MENU
  STAFF
  SHIFT
}

enum TrustActionType {
  DISCOUNT
  REFUND
  COMP
  ORDER_EDIT
  ORDER_CANCEL
  ORDER_STATUS
  PRICE_EDIT
  ROLE_CHANGE
  PERMISSION_CHANGE
}

enum TrustActorContext {
  CUSTOMER
  STAFF
  ADMIN
}

enum TrustDecision {
  ALLOW
  REQUIRE_APPROVAL
  BLOCK
  FLAG
}

enum TrustEventStatus {
  PENDING
  RESOLVED
  FINAL
}

enum FraudDetectorType {
  COI_DETECTED
  DISCOUNT_ABUSE
  REFUND_ABUSE
  VELOCITY_ANOMALY
  ROLE_ABUSE
  IDENTITY_SWITCHING
  COLLUSION
  SHIFT_ANOMALY
  PRICE_MANIPULATION
}

enum ApprovalTaskStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  ESCALATED
}

enum ApprovalRequiredRole {
  MANAGER
  OWNER
  SHIFT_LEAD
  INDEPENDENT_STAFF
}

enum ApprovalActionType {
  APPROVE
  REJECT
  ESCALATE
}

model Order {
  id             String      @id @default(cuid())
  restaurantId   String
  customerUserId String?
  /// User who initiated the order (usually same as customerUserId for customer-placed orders).
  createdByUserId  String?
  /// Locked at creation — staff role switching cannot change financial ownership.
  createdByContext OrderCreatedContext @default(CUSTOMER)
  /// Human-facing ticket number within the venue (e.g. 1042 → "#1042").
  displaySeq     Int?
  /// Period bucket for tenant display number — enables safe yearly/monthly reset without history collision.
  displayPeriodKey String @default("all")
  /// Session / source traceability (QR, staff device, walk-in, reservation).
  sourceSessionId   String?
  sourceSessionType String?
  /// Device that originated the order (staff tablet, kiosk).
  deviceId          String?
  /// Linked reservation when order originated from a booking.
  reservationId     String?
  /// Internal ID schema used at creation — supports cuid → ulid migration path.
  internalIdSchema  String   @default("cuid")
  /// GS1-inspired global trade identifier (derived, immutable).
  gs1Identifier     String?  @unique
  /// Searchable receipt fingerprint for customer/staff lookup.
  receiptSearchHash String?
  /// Global federation key for cross-network order references.
  federationId      String?  @unique
  /// Immutable source placement snapshot (attribution, validation context, policy version).
  sourceMetadata    Json?
  source         OrderSource @default(QR_ORDER)
  status         OrderStatus @default(CREATED)
  paymentStatus  OrderPaymentStatus @default(UNPAID)
  subtotalCents  Int
  taxCents       Int         @default(0)
  serviceFeeCents Int        @default(0)
  discountCents  Int         @default(0)
  refundedCents  Int         @default(0)
  totalCents     Int
  note           String?
  /// Guest / walk-in contact when no customer account.
  customerName   String?
  customerPhone  String?
  customerEmail  String?
  tableLabel     String?
  assignedStaffUserId String?
  /// Frozen after payment confirmed — line pricing must not change after this.
  pricingLockedAt DateTime?
  /// Set when kitchen enters PREPARING — item edits restricted after this.
  kitchenStartedAt DateTime?
  completedAt    DateTime?
  /// Optimistic concurrency — every mutation increments; stale writes rejected.
  version        Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  customer   User?      @relation("CustomerOrders", fields: [customerUserId], references: [id], onDelete: SetNull)
  lines      OrderLineItem[]
  chatRoom   ChatRoom?
  statusHistory OrderStatusHistory[]
  auditLogs  OrderAuditLog[]
  domainEvents OrderDomainEvent[]
  outboxEvents OrderEventOutbox[]
  paymentReferences OrderPaymentReference[]
  recoveryLogs OrderRecoveryLog[]
  compensationLogs OrderCompensationLog[]
  ownershipRecord OrderOwnershipRecord?
  partnerIdentities OrderPartnerIdentity[]

  @@unique([restaurantId, displayPeriodKey, displaySeq])
  @@index([restaurantId, createdAt])
  @@index([restaurantId, status])
  @@index([customerUserId])
  @@index([createdByUserId])
  @@index([sourceSessionId])
  @@index([receiptSearchHash])
  @@index([reservationId])
  @@index([deviceId])
}

/// Immutable ownership snapshot — who owns/created/is accountable for the order at placement.
model OrderOwnershipRecord {
  orderId                 String              @id
  restaurantId            String
  accountableRestaurantId String
  ownershipType           String
  customerUserId          String?
  guestKey                String?
  createdByUserId         String?
  createdByContext        OrderCreatedContext
  assignedStaffUserId     String?
  tableLabel              String?
  reservationId           String?
  deviceId                String?
  source                  OrderSource
  sourceSessionId         String?
  lockedAt                DateTime            @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([customerUserId])
  @@index([guestKey])
  @@index([assignedStaffUserId])
}

/// External partner order mapping (Deliveroo, Uber Eats, POS integrations).
model OrderPartnerIdentity {
  id              String   @id @default(cuid())
  orderId         String
  restaurantId    String
  partnerId       String
  externalOrderId String
  metadata        Json?
  createdAt       DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([partnerId, externalOrderId])
  @@index([orderId])
  @@index([restaurantId, partnerId])
}

/// Atomic per-restaurant order number counter — concurrency-safe tenant display allocation.
model RestaurantOrderCounter {
  restaurantId   String   @id
  /// Monotonic sequence — never decrements; survives display period resets.
  nextSeq        Int      @default(0)
  /// Current display period key (all | 2026 | 2026-06).
  periodKey      String   @default("all")
  /// nextSeq value at period start — human number = nextSeq - periodStartSeq after allocation.
  periodStartSeq Int      @default(0)
  updatedAt      DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

/// Immutable status transition record — append-only.
model OrderStatusHistory {
  id          String       @id @default(cuid())
  orderId     String
  fromStatus  OrderStatus?
  toStatus    OrderStatus
  actorUserId String?
  actorSource OrderActorSource @default(SYSTEM)
  reason      String?
  createdAt   DateTime     @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

/// Operational audit trail — append-only; complements trust-layer audit.
model OrderAuditLog {
  id           String          @id @default(cuid())
  orderId      String
  restaurantId String
  actorUserId  String?
  actorSource  OrderActorSource @default(SYSTEM)
  action       String
  beforeState  Json?
  afterState   Json?
  metadata     Json?
  createdAt    DateTime        @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@index([restaurantId, createdAt])
}

/// Domain events emitted by the order engine — source of truth for downstream consumers.
model OrderDomainEvent {
  id           String   @id @default(cuid())
  orderId      String
  restaurantId String
  type         String
  payload      Json
  createdAt    DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@index([restaurantId, createdAt])
  @@index([type, createdAt])
}

enum OrderOutboxStatus {
  PENDING
  PUBLISHED
  FAILED
}

/// Transactional outbox — events are written in the same DB transaction as order mutations, then published reliably.
model OrderEventOutbox {
  id             String            @id @default(cuid())
  orderId        String
  restaurantId   String
  /// Monotonic per orderId — guarantees downstream ordering.
  sequence       Int
  eventType      String
  schemaVersion  Int               @default(1)
  payload        Json
  status         OrderOutboxStatus @default(PENDING)
  attempts       Int               @default(0)
  lastError      String?
  createdAt      DateTime          @default(now())
  publishedAt    DateTime?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, sequence])
  @@index([status, createdAt])
  @@index([orderId, sequence])
}

/// Idempotency keys for place-order, transitions, and payment webhooks.
model OrderIdempotencyKey {
  id           String   @id @default(cuid())
  scope        String
  key          String
  restaurantId String?
  orderId      String?
  requestHash  String?
  response     Json?
  status       String   @default("IN_PROGRESS")
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  @@unique([scope, key])
  @@index([expiresAt])
}

/// Payment provider references — webhook idempotency via unique (provider, externalId).
model OrderPaymentReference {
  id             String   @id @default(cuid())
  orderId        String
  restaurantId   String
  provider       String
  externalId     String
  amountCents    Int
  currency       String   @default("SEK")
  status         String   @default("PENDING")
  idempotencyKey String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([provider, externalId])
  @@index([orderId])
}

/// Self-healing actions taken by the recovery worker (escalation, reconcile, retry).
model OrderRecoveryLog {
  id           String   @id @default(cuid())
  orderId      String
  restaurantId String
  action       String
  reason       String
  metadata     Json?
  createdAt    DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@index([restaurantId, createdAt])
}

/// Compensation when business state diverges (payment vs order, delivery vs rollback).
model OrderCompensationLog {
  id           String   @id @default(cuid())
  orderId      String
  restaurantId String
  type         String
  trigger      String
  status       String   @default("PENDING")
  beforeState  Json?
  afterState   Json?
  metadata     Json?
  createdAt    DateTime @default(now())
  resolvedAt   DateTime?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@index([restaurantId, status])
}

/// Unified trust layer — fraud, approval, and audit share this root event.
model TrustEvent {
  id           String            @id @default(cuid())
  workspaceId  String
  userId       String
  type         TrustEventType
  entityType   TrustEntityType
  entityId     String
  actionType   TrustActionType
  context      TrustActorContext
  riskScore    Int               @default(0)
  decision     TrustDecision
  status       TrustEventStatus  @default(PENDING)
  payload      Json?
  metadata     Json?
  createdAt    DateTime          @default(now())

  fraudSignals   FraudSignal[]
  fraudScore     FraudScore?
  approvalTask   ApprovalTask?
  auditLogs      TrustAuditLog[]

  @@index([workspaceId, createdAt])
  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@index([type, status])
}

model FraudSignal {
  id            String            @id @default(cuid())
  trustEventId  String
  workspaceId   String
  userId        String
  detectorType  FraudDetectorType
  severity      Int
  reason        Json?
  createdAt     DateTime          @default(now())

  trustEvent TrustEvent @relation(fields: [trustEventId], references: [id], onDelete: Cascade)

  @@index([trustEventId])
  @@index([workspaceId, detectorType])
  @@index([userId, createdAt])
}

model FraudScore {
  id           String        @id @default(cuid())
  trustEventId String        @unique
  finalScore   Int
  decision     TrustDecision
  computedAt   DateTime      @default(now())

  trustEvent TrustEvent @relation(fields: [trustEventId], references: [id], onDelete: Cascade)
}

model ApprovalTask {
  id                String               @id @default(cuid())
  trustEventId      String               @unique
  workspaceId       String
  entityType        TrustEntityType
  entityId          String
  requestedByUserId String
  requiredRole      ApprovalRequiredRole
  status            ApprovalTaskStatus   @default(PENDING)
  riskScore         Int
  expiresAt         DateTime
  executedAt        DateTime?
  createdAt         DateTime             @default(now())

  trustEvent TrustEvent       @relation(fields: [trustEventId], references: [id], onDelete: Cascade)
  actions    ApprovalAction[]

  @@index([workspaceId, status])
  @@index([requestedByUserId])
  @@index([expiresAt])
}

model ApprovalAction {
  id             String             @id @default(cuid())
  approvalTaskId String
  actedByUserId  String
  action         ApprovalActionType
  comment        String?
  createdAt      DateTime           @default(now())

  approvalTask ApprovalTask @relation(fields: [approvalTaskId], references: [id], onDelete: Cascade)

  @@index([approvalTaskId])
  @@index([actedByUserId])
}

/// Immutable forensic history for trust-layer actions.
model TrustAuditLog {
  id           String          @id @default(cuid())
  trustEventId String
  workspaceId  String
  actorId      String
  actionType   TrustActionType
  entityType   TrustEntityType
  entityId     String
  beforeState  Json?
  afterState   Json?
  ipAddress    String?
  deviceId     String?
  createdAt    DateTime        @default(now())

  trustEvent TrustEvent @relation(fields: [trustEventId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([entityType, entityId])
  @@index([actorId])
}

enum ChatRoomType {
  ORDER
  RESERVATION
  VENUE
  STAFF
  SUPPORT
}

enum ChatMessageType {
  TEXT
  IMAGE
  SYSTEM
  ACTION
}

model ChatRoom {
  id             String       @id @default(cuid())
  type           ChatRoomType
  restaurantId   String
  orderId        String?      @unique
  reservationId  String?    @unique
  customerUserId String?
  lastMessageAt          DateTime?
  lastMessagePreview     String?
  lastMessageSenderRole  String?
  customerLastReadAt     DateTime?
  restaurantLastReadAt   DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  restaurant Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  order        Order?               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reservation  CustomerReservation? @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  customer     User?                @relation("CustomerChatRooms", fields: [customerUserId], references: [id], onDelete: Cascade)
  messages   ChatMessage[]

  @@unique([type, restaurantId, customerUserId])
  @@index([restaurantId])
  @@index([customerUserId])
}

model ChatMessage {
  id           String          @id @default(cuid())
  chatRoomId   String
  senderUserId String?
  senderRole   String
  content      String
  type         ChatMessageType @default(TEXT)
  deliveredToVenueAt DateTime?
  createdAt    DateTime        @default(now())

  chatRoom ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)

  @@index([chatRoomId, createdAt])
}

model OrderLineItem {
  id                 String   @id @default(cuid())
  orderId            String
  menuItemId         String
  nameSnapshot       String
  quantity           Int
  unitPriceCents     Int
  selectedModifiers Json?
  lineTotalCents     Int
  createdAt          DateTime @default(now())

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([orderId])
}

model ModifierGroup {
  id         String   @id @default(cuid())
  menuItemId String
  name       String
  minSelect  Int      @default(0)
  maxSelect  Int      @default(1)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  menuItem MenuItem         @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  options  ModifierOption[]

  @@index([menuItemId])
}

model ModifierOption {
  id              String   @id @default(cuid())
  modifierGroupId String
  name            String
  priceDeltaCents Int      @default(0)
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  group ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@index([modifierGroupId])
}

enum NotificationCategory {
  ORDER
  CHAT
  RESERVATION
  SYSTEM
  PAYMENT
  STAFF
}

enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

/// In-app notification inbox — all alerts persist here regardless of channel.
model Notification {
  id           String               @id @default(cuid())
  userId       String
  restaurantId String?
  category     NotificationCategory
  eventKey     String
  title        String
  body         String
  payload      Json
  priority     NotificationPriority @default(MEDIUM)
  channels     Json
  readAt       DateTime?
  createdAt    DateTime             @default(now())

  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries NotificationDelivery[]

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([restaurantId])
}

/// Per-channel delivery attempts (email, push, SMS, etc.).
model NotificationDelivery {
  id             String                     @id @default(cuid())
  notificationId String
  channel        String
  status         NotificationDeliveryStatus @default(PENDING)
  attempts       Int                        @default(0)
  lastError      String?
  externalId     String?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@index([channel, status])
}

/// FCM device tokens for mobile/web push delivery (HTTP v1 via Firebase Admin SDK).
model UserDeviceToken {
  id         String    @id @default(cuid())
  userId     String
  token      String    @unique
  platform   String?
  deviceName String?
  lastSeenAt DateTime  @default(now())
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
}

/// User delivery preferences — CRITICAL events bypass these in the routing engine.
model UserNotificationPreference {
  userId          String   @id
  pushEnabled     Boolean  @default(true)
  emailEnabled    Boolean  @default(true)
  smsEnabled      Boolean  @default(false)
  whatsappEnabled Boolean  @default(false)
  quietHours      Json?
  categoryFlags   Json?
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Marketing / newsletter / non-critical communication opt-in — separate from billing and transactional mail.
model CommunicationSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  userId         String?   @unique
  tokenHash      String    @unique
  tokenExpiresAt DateTime?
  emailPrefs     Json
  inAppPrefs     Json
  lastSource     String?
  updatedAt      DateTime  @updatedAt
  createdAt      DateTime  @default(now())

  user   User?                          @relation(fields: [userId], references: [id], onDelete: SetNull)
  audits CommunicationPreferenceAudit[]

  @@index([userId])
}

model CommunicationPreferenceAudit {
  id           String   @id @default(cuid())
  subscriberId String
  action       String
  source       String
  category     String?
  metadata     Json?
  createdAt    DateTime @default(now())

  subscriber CommunicationSubscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([subscriberId, createdAt])
}

/// Venue staff administration audit trail — actor is admin, target is staff user.
enum StaffAuditAction {
  INVITE_SENT
  INVITE_CANCELLED
  INVITE_ACCEPTED
  MEMBERSHIP_APPROVED
  MEMBERSHIP_REJECTED
  MEMBERSHIP_SUSPENDED
  MEMBERSHIP_ACTIVATED
  MEMBERSHIP_REMOVED
  MEMBERSHIP_RESTORED
  PERMISSIONS_UPDATED
  SESSIONS_REVOKED
  PASSWORD_RESET_REQUESTED
  IDENTITY_MERGED
}

model StaffAuditLog {
  id                   String           @id @default(cuid())
  restaurantId         String
  actorUserId          String
  targetUserId         String?
  targetMembershipId   String?
  action               StaffAuditAction
  metadata             Json?
  createdAt            DateTime         @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  actor      User       @relation("StaffAuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  target     User?      @relation("StaffAuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([restaurantId, createdAt])
  @@index([targetUserId])
  @@index([targetMembershipId])
}

