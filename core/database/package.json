{
  "name": "@serveos/core-database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "prisma": {
    "seed": "tsx ./prisma/seed.ts"
  },
  "scripts": {
    "db:generate": "tsx ./scripts/prisma-with-env.ts generate",
    "db:migrate:dev": "tsx ./scripts/prisma-with-env.ts migrate dev",
    "db:migrate:deploy": "tsx ./scripts/prisma-with-env.ts migrate deploy",
    "db:migrate:status": "tsx ./scripts/prisma-with-env.ts migrate status",
    "db:push": "tsx ./scripts/prisma-with-env.ts db push",
    "db:studio": "tsx ./scripts/prisma-with-env.ts studio",
    "db:seed": "tsx ./scripts/prisma-with-env.ts db seed"
  },
  "dependencies": {
    "@prisma/client": "^6.16.1"
  },
  "devDependencies": {
    "dotenv": "^16.6.1",
    "prisma": "^6.16.1",
    "tsx": "^4.20.6"
  }
}

