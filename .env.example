NODE_ENV=development

HOST=127.0.0.1

# Database (Neon PostgreSQL). Prisma Migrate + Prisma Studio need a working TCP connection to port 5432.
#
# If `prisma migrate` / Studio show P1001 ("Can't reach database server"):
# - In Neon: open the project, ensure the branch isn’t deleted and the compute isn’t stuck; free tier resumes on use.
# - Prefer Neon's "Direct connection" URI (host like ep-xxxx.region.aws.neon.tech WITHOUT "-pooler") for migrate + Studio.
#   Pooler URLs often work for the app runtime but direct is more reliable for migrations and tooling.
# - Check VPN/firewall/corporate network blocking outbound Postgres (5432).
#
DATABASE_URL="postgresql://USER:PASSWORD@ep-example.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Redis (upstash)
UPSTASH_REDIS_REST_URL="https://relaxing-mutt-102720.upstash.io" 
UPSTASH_REDIS_REST_TOKEN="gQAAAAAAAZFAAAIocDE2YTc4MmY2OGJjZGQ0NDAxYjlhOGJlMjdjYzk5NGVjOXAxMTAyNzIw"

# Auth
JWT_SECRET=674cfe389c7a961e5e2403148eb3b860cdb99d2ed2c072d5393847bc0d792010e6f3bf355aeb43db92fb65bb590980c7be71c56e77df73d57862d7283050dbc2

# Transactional email (Resend — required for production auth/account flows)
RESEND_API_KEY=
RESEND_FROM_EMAIL=ServeOS <noreply@mail.serveos.se>
CUSTOMER_WEB_URL=https://your-customer-web.onrender.com
WEB_ADMIN_URL=https://your-web-admin.onrender.com
SERVEOS_PREFERENCES_BASE_URL=https://your-customer-web.onrender.com/preferences
API_PUBLIC_URL=https://serveos-api.onrender.com

# Notifications (optional — email is primary; SMS via Twilio when configured)
# SERVEOS_INVITE_BASE_URL=https://your-customer-web.onrender.com/invite
# NOTIFICATION_INGEST_SECRET=
# Twilio SMS (trial accounts: verify recipient numbers in Twilio console)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Push notifications (Firebase Admin SDK — FCM HTTP v1)
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
# Or mount JSON as a file on the server:
# FIREBASE_SERVICE_ACCOUNT_PATH=/etc/secrets/firebase-service-account.json

# Services
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
RESTAURANT_SERVICE_PORT=3002
ORDER_SERVICE_PORT=3003

# Seed a demo venue + full menu after migrations: npm run db:seed
# Paste this Restaurant ID in the mobile Account tab as go-to venue (or use Expo demo menu below).
# SERVEOS_DEMO_RESTAURANT_ID=serveos_demo_peak_bistro

# Object storage (AWS S3 — primary storage; required for uploads in production)
# Standard AWS names are preferred; AWS_S3_* aliases are also supported.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-north-1
AWS_S3_BUCKET=serveos-media-prod
# Optional public URL prefix when not using Cloudflare (otherwise signed URLs for private reads)
# AWS_S3_PUBLIC_URL=
# Cloudflare CDN cache layer in front of S3 (purge only — not DNS/domain management)
CLOUDFLARE_CDN_URL=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=
# Optional custom S3-compatible endpoint (not needed for AWS)
# AWS_S3_ENDPOINT=

# Error monitoring (Sentry — API only; clients fetch DSN via GET /config/client)
SENTRY_DSN=
# Optional release + sampling overrides
# SENTRY_CLIENT_DSN=
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Mobile-only: full homepage menu UI without hitting the API (same copy as db seed).
# Create apps/mobile-app/.env with EXPO_PUBLIC_SERVEOS_USE_DEMO_MENU=true and restart Expo.
# EXPO_PUBLIC_SERVEOS_USE_DEMO_MENU=true

