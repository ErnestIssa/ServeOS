# Public API URL (Expo bakes this in at build time). Use a **valid** URL: `http://` or `https://`
# (Typos like `http//192.168.x.x` are auto-corrected in code.)
#
# Physical device + local API (same Wi‑Fi as your machine):
# EXPO_PUBLIC_API_URL=http://192.168.1.10:3000
#
# Release builds with no env use https://serveos-api.onrender.com
# EXPO_PUBLIC_API_URL=https://serveos-api.onrender.com
